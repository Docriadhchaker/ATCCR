# PostgreSQL — pooler for app queries (Supabase port 6543, or local Docker)
# Supabase: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Local:    postgresql://postgres:postgres@localhost:5432/atccr?schema=public
DATABASE_URL=

# PostgreSQL — direct connection for Prisma migrations (Supabase port 5432)
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Demo super admin password (local seed only — never commit a real value)
DEMO_ADMIN_PASSWORD=

# Auth.js base URL (required when Auth.js is enabled)
AUTH_URL=http://localhost:3000

# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local file storage path (Phase 0)
STORAGE_LOCAL_PATH=./storage
